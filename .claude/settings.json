{
	"$schema": "https://code.claude.com/settings.schema.json",
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/warn-untested.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Edit|Write",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/post-edit-touch.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/stop-audit-gate.sh"
					}
				]
			}
		]
	}
}
